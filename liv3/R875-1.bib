@article{obbard1981,
  title = {A {{Radio-Telemetry}} and {{Mark-Recapture Study}} of {{Activity}} in the {{Common Snapping Turtle}}, {{Chelydra}} Serpentina},
  author = {Obbard, Martyn E. and Brooks, Ronald J.},
  date = {1981},
  journaltitle = {Copeia},
  volume = {1981},
